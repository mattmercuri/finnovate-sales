{
  "name": "finnovate-sales",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "api:generate": "pnpm --filter @finnovate-sales/web run api:generate",
    "db:generate": "pnpm --filter @finnovate-sales/db exec prisma generate",
    "db:migrate": "pnpm --filter @finnovate-sales/db exec prisma migrate dev",
    "db:push": "pnpm --filter @finnovate-sales/db exec prisma db push",
    "db:studio": "pnpm --filter @finnovate-sales/db exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.15",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "22.x"
  }
}